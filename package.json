{
  "name": "rs-levels",
  "version": "0.0.0",
  "description": "Local-first RocketScooter level capture and display feeds.",
  "scripts": {
    "start": "node apps/local-service/src/cli.js",
    "demo:capture": "node tools/post-sample-capture.mjs",
    "package": "node tools/package-release.mjs",
    "package:check": "node tools/package-release.mjs --check",
    "test": "npm run test:schemas && npm run test:parser && npm run test:exporters && npm run test:service && npm run test:tradingview && npm run test:extension && npm run test:openapi && npm run test:examples && npm run test:plugins && npm run test:tools && npm run package:check",
    "test:schemas": "node packages/schemas/test/validate-samples.test.js",
    "test:parser": "node packages/core-parser/test/core-parser.test.js",
    "test:exporters": "node packages/exporters/test/exporters.test.js",
    "test:service": "node apps/local-service/test/local-service.test.js",
    "test:tradingview": "node plugins/tradingview/test/tradingview.test.cjs",
    "test:extension": "node apps/browser-extension/test/extension.test.cjs && node apps/browser-extension/test/extension-logic.test.cjs",
    "test:openapi": "node docs/test/openapi.test.cjs",
    "test:examples": "node examples/test/examples.test.cjs",
    "test:plugins": "node plugins/test/plugin-docs.test.cjs",
    "test:tools": "node tools/test/scan-text.test.cjs",
    "scan:private": "node tools/scan-text.mjs private",
    "scan:secrets": "node tools/scan-text.mjs secrets"
  },
  "keywords": [
    "rocketscooter",
    "levels",
    "local-api",
    "charting"
  ],
  "license": "UNLICENSED"
}
