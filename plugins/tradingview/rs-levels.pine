//@version=6
indicator("RS Levels v2026.07.09.5", overlay = true, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 500)

payload = input.string("", "RS Levels Payload", display = display.none)
chartFamilyInput = input.string("Auto", "Chart family", options = ["Auto", "ES", "NQ"], display = display.none)
labelLayoutInput = input.string("Rail", "Label layout", options = ["Rail", "On line", "Hidden"])
showLabels = labelLayoutInput != "Hidden"
showStatsPanel = input.bool(true, "Stats panel")
statsPanelPositionInput = input.string("Bottom left", "Stats panel position", options = ["Bottom left", "Bottom center", "Bottom right", "Middle left", "Middle right", "Top left", "Top right"], display = display.none)
statsPanelBottomPaddingInput = input.int(4, "Stats panel bottom padding", minval = 0, maxval = 20, display = display.none)
showDdBands = input.bool(true, "DD bands", inline = "dd")
ddBandColorInput = input.color(color.rgb(0, 188, 212), "", inline = "dd")
showHp = input.bool(true, "HP", inline = "hp")
hpColorInput = input.color(color.rgb(41, 98, 255), "", inline = "hp")
showMhp = input.bool(true, "MHP", inline = "mhp")
mhpColorInput = input.color(color.rgb(255, 152, 0), "", inline = "mhp")
showOpenClose = input.bool(true, "Open/close", inline = "openClose")
openCloseColorInput = input.color(color.rgb(255, 255, 255), "", inline = "openClose")
showReference = input.bool(true, "References", inline = "reference")
referenceColorInput = input.color(color.rgb(255, 235, 59), "", inline = "reference")
showYellowLines = input.bool(true, "Yellow lines", inline = "yellowLine")
yellowLineColorInput = input.color(color.rgb(255, 235, 59), "", inline = "yellowLine")
showRedLines = input.bool(true, "Red lines", inline = "redLine")
redLineColorInput = input.color(color.rgb(242, 54, 69), "", inline = "redLine")
showCatLines = input.bool(true, "CAT lines", inline = "catLine")
catLineColorInput = input.color(color.rgb(126, 87, 194), "", inline = "catLine")
showBullZones = input.bool(true, "Bull zones", inline = "bullZone")
bullZoneColorInput = input.color(color.rgb(76, 175, 80), "", inline = "bullZone")
showBearZones = input.bool(true, "Bear zones", inline = "bearZone")
bearZoneColorInput = input.color(color.rgb(242, 54, 69), "", inline = "bearZone")
showZoneFills = input.bool(true, "Zone fills")
showOtherLevels = input.bool(true, "Other levels", inline = "otherLevels")
otherLevelColorInput = input.color(color.rgb(158, 158, 158), "", inline = "otherLevels")
lineWidth = input.int(1, "Line width", minval = 1, maxval = 4, display = display.none)
fontSizeInput = input.string("Small", "Font size", options = ["Tiny", "Small", "Normal", "Large", "Huge"], display = display.none)
railInsetPercentInput = input.int(2, "Rail inset %", minval = 0, maxval = 20, display = display.none)
labelVerticalOffset = input.int(6, "Min label vertical offset (ticks)", minval = 1, maxval = 100, display = display.none)
zoneFillOpacityInput = input.int(12, "Zone fill opacity %", minval = 0, maxval = 50, display = display.none)
maxLevelsInput = input.int(200, "Max levels", minval = 1, maxval = 500, display = display.none)
lineStyleInput = input.string("Solid", "Line style", options = ["Solid", "Dashed", "Dotted"], display = display.none)

statsPanelPosition() =>
    switch statsPanelPositionInput
        "Bottom center" => position.bottom_center
        "Bottom right" => position.bottom_right
        "Top right" => position.top_right
        "Top left" => position.top_left
        "Middle left" => position.middle_left
        "Middle right" => position.middle_right
        => position.bottom_left

statsPanelSpacerHeight() =>
    statsPanelPositionInput == "Bottom left" ? statsPanelBottomPaddingInput : 0

var line[] rsLines = array.new_line()
var label[] rsLabels = array.new_label()
var box[] rsBoxes = array.new_box()
var string[] rsLabelKeys = array.new_string()
var float[] rsLabelBasePrices = array.new_float()
var table rsStatsTable = table.new(statsPanelPosition(), 1, 3)
var float visibleHigh = na
var float visibleLow = na

barInVisibleWindow = time >= chart.left_visible_bar_time and time <= chart.right_visible_bar_time
if time < chart.left_visible_bar_time
    visibleHigh := na
    visibleLow := na
else if barInVisibleWindow
    visibleHigh := na(visibleHigh) ? high : math.max(visibleHigh, high)
    visibleLow := na(visibleLow) ? low : math.min(visibleLow, low)

visibleBarRange = not na(visibleHigh) and not na(visibleLow) ? math.max(visibleHigh - visibleLow, syminfo.mintick) : syminfo.mintick

clearDrawings() =>
    while array.size(rsBoxes) > 0
        box.delete(array.pop(rsBoxes))
    while array.size(rsLines) > 0
        line.delete(array.pop(rsLines))
    while array.size(rsLabels) > 0
        label.delete(array.pop(rsLabels))
    array.clear(rsLabelKeys)
    array.clear(rsLabelBasePrices)

cleanKind(kind) =>
    compactKind = str.lower(str.replace_all(kind, " ", ""))
    compactKind := str.replace_all(compactKind, "_", "")
    compactKind := str.replace_all(compactKind, "-", "")
    switch compactKind
        "ddband" => "dd-band"
        "openclose" => "open-close"
        "yellowline" => "yellow-line"
        "redline" => "red-line"
        "catline" => "cat"
        "zonebull" => "zone-bull"
        "bullzone" => "zone-bull"
        "zonebear" => "zone-bear"
        "bearzone" => "zone-bear"
        => compactKind

compactText(sourceText) =>
    compact = str.upper(sourceText)
    compact := str.replace_all(compact, " ", "")
    compact := str.replace_all(compact, "_", "")
    compact := str.replace_all(compact, "-", "")
    compact

zoneKindFromName(name) =>
    upperName = str.upper(name)
    compactName = compactText(name)
    if str.contains(compactName, "BRZT") or str.contains(compactName, "BRZB") or str.contains(compactName, "BEARZONE") or str.contains(compactName, "BEAZONE") or str.contains(upperName, "BEAR ZONE") or str.contains(upperName, "BEA ZONE")
        "zone-bear"
    else if str.contains(compactName, "BZT") or str.contains(compactName, "BZB") or str.contains(compactName, "BULLZONE") or str.contains(upperName, "BULL ZONE")
        "zone-bull"
    else
        ""

zoneSideKind(name, kind) =>
    namedZoneKind = zoneKindFromName(name)
    normalizedKind = cleanKind(kind)
    if namedZoneKind != ""
        namedZoneKind
    else if normalizedKind == "zone-bull" or normalizedKind == "zone-bear"
        normalizedKind
    else
        ""

levelKind(name, kind) =>
    upperName = str.upper(name)
    compactName = compactText(name)
    normalizedKind = cleanKind(kind)
    sideKind = zoneSideKind(name, kind)
    if str.contains(upperName, "CAT") or str.contains(compactName, "CAT")
        "cat"
    else if str.contains(upperName, "YELLOW LINE") or str.contains(compactName, "YELLOWLINE") or str.startswith(upperName, "YL")
        "yellow-line"
    else if str.contains(upperName, "RED LINE") or str.contains(compactName, "REDLINE") or str.startswith(upperName, "RL")
        "red-line"
    else if sideKind != ""
        sideKind
    else
        normalizedKind

kindColor(kind) =>
    normalizedKind = cleanKind(kind)
    switch normalizedKind
        "dd-band" => ddBandColorInput
        "hp" => hpColorInput
        "mhp" => mhpColorInput
        "open-close" => openCloseColorInput
        "reference" => referenceColorInput
        "yellow-line" => yellowLineColorInput
        "red-line" => redLineColorInput
        "cat" => catLineColorInput
        "zone-bull" => bullZoneColorInput
        "zone-bear" => bearZoneColorInput
        => otherLevelColorInput

kindEnabled(kind) =>
    normalizedKind = cleanKind(kind)
    switch normalizedKind
        "dd-band" => showDdBands
        "hp" => showHp
        "mhp" => showMhp
        "open-close" => showOpenClose
        "reference" => showReference
        "yellow-line" => showYellowLines
        "red-line" => showRedLines
        "cat" => showCatLines
        "zone-bull" => showBullZones
        "zone-bear" => showBearZones
        "stat" => false
        => showOtherLevels

zoneKind(kind) =>
    normalizedKind = cleanKind(kind)
    normalizedKind == "zone-bull" or normalizedKind == "zone-bear"

zoneBoundarySide(name) =>
    compactName = compactText(name)
    if str.contains(compactName, "TOP") or str.contains(compactName, "UPPER") or str.contains(compactName, "BZT") or str.contains(compactName, "BRZT")
        1
    else if str.contains(compactName, "BOTTOM") or str.contains(compactName, "LOWER") or str.contains(compactName, "BZB") or str.contains(compactName, "BRZB")
        -1
    else
        0

zoneBoundaryLabel(kind, side) =>
    normalizedKind = cleanKind(kind)
    if normalizedKind == "zone-bull"
        side == 1 ? "Bull Zone Top" : side == -1 ? "Bull Zone Bottom" : "Bull Zone"
    else if normalizedKind == "zone-bear"
        side == 1 ? "Bear Zone Top" : side == -1 ? "Bear Zone Bottom" : "Bear Zone"
    else
        "Zone"

halfGapLevel(name) =>
    upperName = str.upper(name)
    str.contains(upperName, "MIDGAP") or str.contains(upperName, "MID GAP") or str.contains(upperName, "HALFGAP") or str.contains(upperName, "HALF GAP") or str.contains(upperName, " HG")

lineStyle() =>
    switch lineStyleInput
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

lineStyleForLevel(name, kind) =>
    halfGapLevel(name) ? line.style_dashed : lineStyle()

labelSize() =>
    switch fontSizeInput
        "Tiny" => size.tiny
        "Normal" => size.normal
        "Large" => size.large
        "Huge" => size.huge
        => size.small

displayLabelNameForSide(name, kind, zoneSide) =>
    upperName = str.upper(name)
    compactName = compactText(name)
    normalizedKind = cleanKind(kind)
    effectiveZoneKind = zoneSideKind(name, kind)
    effectiveZoneKind := effectiveZoneKind != "" ? effectiveZoneKind : normalizedKind
    effectiveZoneSide = zoneSide != 0 ? zoneSide : zoneBoundarySide(name)
    if zoneKind(effectiveZoneKind)
        zoneBoundaryLabel(effectiveZoneKind, effectiveZoneSide)
    else if str.contains(upperName, "PREVDAYCLOSE") or str.contains(upperName, "PREV DAY CLOSE")
        "Prev Close"
    else if halfGapLevel(name)
        "Half Gap"
    else if str.contains(upperName, "LASTOPEN") or (str.contains(upperName, "OPEN") and not str.contains(upperName, "CLOSE"))
        "Open"
    else if str.contains(upperName, "CLOSE")
        "Close"
    else if str.contains(upperName, "OVNMHP")
        "OVNMHP"
    else if str.contains(upperName, "OVNHP")
        "OVNHP"
    else if normalizedKind == "mhp" or str.contains(upperName, "MAN_MHP") or str.contains(upperName, " MHP")
        "MHP"
    else if normalizedKind == "hp" or str.contains(upperName, "MAN_HP") or str.contains(upperName, " HP")
        "HP"
    else if normalizedKind == "dd-band" or str.contains(upperName, "DD")
        "DD"
    else if normalizedKind == "cat" or str.contains(upperName, "CAT") or str.contains(compactName, "CAT")
        "CAT"
    else if normalizedKind == "yellow-line" or str.contains(upperName, "YELLOW LINE") or str.contains(compactName, "YELLOWLINE") or upperName == "YL"
        "Yellow Line"
    else if normalizedKind == "red-line" or str.contains(upperName, "RED LINE") or str.contains(compactName, "REDLINE") or upperName == "RL"
        "Red Line"
    else
        cleaned = str.replace_all(name, "horizontal_line", "")
        cleaned := str.replace_all(cleaned, "horizontalLine", "")
        cleaned := str.replace_all(cleaned, "HorizontalLine", "")
        cleaned := str.replace_all(cleaned, "HORIZONTALLINE", "")
        cleaned := str.replace_all(cleaned, "Horizontal_Line", "")
        cleaned := str.replace_all(cleaned, "Horizontal_line", "")
        cleaned := str.replace_all(cleaned, "HORIZONTAL_LINE", "")
        cleaned := str.replace_all(cleaned, "horizontal line", "")
        cleaned := str.replace_all(cleaned, "Horizontal Line", "")
        cleaned := str.replace_all(cleaned, "HORIZONTAL LINE", "")
        cleaned := str.replace_all(cleaned, "horizontal_ray", "")
        cleaned := str.replace_all(cleaned, "horizontalRay", "")
        cleaned := str.replace_all(cleaned, "HorizontalRay", "")
        cleaned := str.replace_all(cleaned, "HORIZONTALRAY", "")
        cleaned := str.replace_all(cleaned, "Horizontal_Ray", "")
        cleaned := str.replace_all(cleaned, "Horizontal_ray", "")
        cleaned := str.replace_all(cleaned, "HORIZONTAL_RAY", "")
        cleaned := str.replace_all(cleaned, "horizontal", "")
        cleaned := str.replace_all(cleaned, "Horizontal", "")
        cleaned := str.replace_all(cleaned, "HORIZONTAL", "")
        cleaned := str.replace_all(cleaned, "Liquidity Map", "")
        cleaned := str.replace_all(cleaned, "liq-map-history", "")
        cleaned := str.replace_all(cleaned, "text", "")
        cleaned := str.replace_all(cleaned, ":", " ")
        compactCleaned = str.replace_all(cleaned, " ", "")
        compactCleaned := str.replace_all(compactCleaned, "_", "")
        compactUpper = str.upper(compactCleaned)
        compactCleaned == "" or compactUpper == "LINE" or compactUpper == "RAY" ? "Level" : cleaned

displayLabelName(name, kind) =>
    displayLabelNameForSide(name, kind, zoneBoundarySide(name))

chartPayloadSymbol() =>
    if chartFamilyInput != "Auto"
        chartFamilyInput
    else
        rootText = str.upper(syminfo.root)
        tickerText = str.upper(syminfo.ticker)
        tickerIdText = str.upper(syminfo.tickerid)
        descriptionText = str.upper(syminfo.description)
        futuresChart = syminfo.type == "futures"
        nqChart = futuresChart and (rootText == "NQ" or rootText == "MNQ" or str.startswith(tickerText, "NQ") or str.startswith(tickerText, "MNQ") or str.contains(tickerIdText, ":NQ") or str.contains(tickerIdText, ":MNQ") or str.contains(descriptionText, "NASDAQ"))
        esChart = futuresChart and (rootText == "ES" or rootText == "MES" or str.startswith(tickerText, "ES") or str.startswith(tickerText, "MES") or str.contains(tickerIdText, ":ES") or str.contains(tickerIdText, ":MES") or str.contains(descriptionText, "S&P 500") or str.contains(descriptionText, "SP 500") or str.contains(descriptionText, "SP500"))
        nqChart ? "NQ" : esChart ? "ES" : tickerText

payloadCompact(payloadText) =>
    cleaned = str.replace_all(payloadText, "\r", "")
    cleaned := str.replace_all(cleaned, "\n", "")
    cleaned := str.replace_all(cleaned, "\t", "")
    cleaned

payloadSymbolLevelText(payloadText, symbolText) =>
    levelText = ""
    parts = str.split(payloadCompact(payloadText), "|")
    if array.size(parts) >= 6 and array.get(parts, 0) == "RSLEVELS" and array.get(parts, 1) == "2"
        for sectionIndex = 3 to array.size(parts) - 3 by 3
            if array.get(parts, sectionIndex) == symbolText
                levelText := array.get(parts, sectionIndex + 2)
    levelText

bestPayloadLevelText(payloadText, chartSymbol) =>
    directLevelText = payloadSymbolLevelText(payloadText, chartSymbol)
    esLevelText = payloadSymbolLevelText(payloadText, "ES")
    nqLevelText = payloadSymbolLevelText(payloadText, "NQ")
    levelText = ""
    if directLevelText != ""
        levelText := directLevelText
    else if chartSymbol == "ES"
        levelText := esLevelText
    else if chartSymbol == "NQ"
        levelText := nqLevelText
    levelText

levelTextForChart(payloadText) =>
    chartSymbol = chartPayloadSymbol()
    bestPayloadLevelText(payloadText, chartSymbol)

statValue(levelText, metricName) =>
    value = ""
    target = str.upper(metricName)
    if levelText != ""
        items = str.split(levelText, ";")
        for i = 0 to array.size(items) - 1
            fields = str.split(array.get(items, i), ",")
            if array.size(fields) >= 3
                name = array.get(fields, 0)
                kind = array.get(fields, 2)
                normalizedKind = cleanKind(kind)
                upperName = str.upper(name)
                if normalizedKind == "stat"
                    if target == "MAP" and str.startswith(upperName, "MAP")
                        mapText = str.replace_all(name, "Map ", "")
                        mapText := str.replace_all(mapText, "MAP ", "")
                        value := mapText
                    else if upperName == target
                        value := array.get(fields, 1)
    value

appendStatText(existingText, label, value) =>
    value == "" ? existingText : existingText == "" ? label + " " + value : existingText + "  " + label + " " + value

statsPanelBody(levelText) =>
    lineText = ""
    lineText := appendStatText(lineText, "RI", statValue(levelText, "RI"))
    lineText

drawStatsPanel(levelText) =>
    mapText = statValue(levelText, "MAP")
    bodyText = statsPanelBody(levelText)
    hasStats = mapText != "" or bodyText != ""
    if showStatsPanel and hasStats
        symbolText = chartPayloadSymbol()
        headerText = (symbolText == "" ? "RS Levels" : symbolText) + (mapText == "" ? "" : "  Map " + mapText)
        table.cell(rsStatsTable, 0, 0, headerText, text_color = color.white, bgcolor = color.new(color.black, 15), text_size = labelSize())
        table.cell(rsStatsTable, 0, 1, bodyText, text_color = color.white, bgcolor = color.new(color.black, 15), text_size = labelSize())
        table.cell(rsStatsTable, 0, 2, "", bgcolor = color.new(color.black, 100), height = statsPanelSpacerHeight())
    else
        table.cell(rsStatsTable, 0, 0, "", bgcolor = color.new(color.black, 100))
        table.cell(rsStatsTable, 0, 1, "", bgcolor = color.new(color.black, 100))
        table.cell(rsStatsTable, 0, 2, "", bgcolor = color.new(color.black, 100), height = statsPanelSpacerHeight())

labelDirection(name, kind) =>
    upperName = str.upper(name)
    normalizedKind = cleanKind(kind)
    if str.contains(upperName, "LOWER") or str.contains(upperName, "BZB") or str.contains(upperName, "BRZB")
        -1
    else if str.contains(upperName, "UPPER") or str.contains(upperName, "BZT") or str.contains(upperName, "BRZT")
        1
    else
        switch normalizedKind
            "mhp" => -1
            "zone-bull" => -1
            "zone-bear" => 1
            "dd-band" => -1
            => 1

labelDirectionForSide(name, kind, zoneSide) =>
    zoneKind(kind) and zoneSide != 0 ? zoneSide : labelDirection(name, kind)

onLineLabelTime(labelSlot) =>
    visibleTimeSpan = math.max(chart.right_visible_bar_time - chart.left_visible_bar_time, 1)
    spreadSlot = math.min(labelSlot, 6)
    spreadStep = int((spreadSlot + 1) / 2) * 6
    anchorPercent = 68 + (spreadSlot % 2 == 1 ? spreadStep : -spreadStep)
    chart.left_visible_bar_time + int(visibleTimeSpan * anchorPercent / 100)

railLabelTime() =>
    visibleTimeSpan = math.max(chart.right_visible_bar_time - chart.left_visible_bar_time, 1)
    chart.right_visible_bar_time - int(visibleTimeSpan * railInsetPercentInput / 100)

labelClusterThreshold(priceRange) =>
    math.max(labelVerticalOffset * syminfo.mintick * 2.0, math.max(priceRange, syminfo.mintick) * 0.002)

labelStackSlot(price, priceRange) =>
    slot = 0
    threshold = labelClusterThreshold(priceRange)
    if array.size(rsLabelBasePrices) > 0
        for i = 0 to array.size(rsLabelBasePrices) - 1
            if math.abs(array.get(rsLabelBasePrices, i) - price) <= threshold
                slot += 1
    array.push(rsLabelBasePrices, price)
    slot

labelOffset(labelSlot, priceRange, isZoneLabel) =>
    stackMultiplier = math.min(labelSlot, 20)
    tickOffset = math.max(labelVerticalOffset * stackMultiplier * syminfo.mintick, syminfo.mintick)
    rangeUnit = math.max(priceRange, syminfo.mintick) * (isZoneLabel ? 0.0012 : 0.0025)
    cappedRangeUnit = math.min(rangeUnit, syminfo.mintick * (isZoneLabel ? 12 : 24))
    rangeOffset = cappedRangeUnit * stackMultiplier
    labelSlot == 0 ? 0.0 : math.max(tickOffset, rangeOffset)

onLineLabelOffset(priceRange) =>
    math.max(syminfo.mintick * 4, math.min(math.max(priceRange, syminfo.mintick) * 0.001, syminfo.mintick * 12))

labelPrice(name, kind, price, labelSlot, priceRange, zoneSide) =>
    direction = labelDirectionForSide(name, kind, zoneSide)
    labelLayoutInput == "Rail" ? price + labelOffset(labelSlot, priceRange, zoneKind(kind)) * direction : price + onLineLabelOffset(priceRange) * direction

labelAlreadyDrawn(labelKey) =>
    seen = false
    if array.size(rsLabelKeys) > 0
        for i = 0 to array.size(rsLabelKeys) - 1
            if array.get(rsLabelKeys, i) == labelKey
                seen := true
    seen

drawLevel(name, priceText, kind, priceRange, zoneSide) =>
    price = str.tonumber(priceText)
    effectiveKind = levelKind(name, kind)
    drawn = false
    if not na(price) and kindEnabled(effectiveKind)
        levelColor = kindColor(effectiveKind)
        newLine = line.new(bar_index - 1, price, bar_index, price, extend = extend.both, color = levelColor, width = lineWidth, style = lineStyleForLevel(name, effectiveKind))
        array.push(rsLines, newLine)
        if showLabels and array.size(rsLabels) < 499
            labelName = displayLabelNameForSide(name, effectiveKind, zoneSide)
            labelText = labelName + " · " + str.tostring(price, format.mintick)
            labelKey = cleanKind(effectiveKind) + "|" + labelName + "|" + str.tostring(price, format.mintick)
            if not labelAlreadyDrawn(labelKey)
                labelSlot = labelStackSlot(price, priceRange)
                labelY = labelPrice(name, effectiveKind, price, labelSlot, priceRange, zoneSide)
                railXTime = railLabelTime()
                if labelLayoutInput == "Rail" and labelY != price and maxLevelsInput <= 250 and array.size(rsLines) < 499
                    leaderLine = line.new(time, price, railXTime, labelY, xloc = xloc.bar_time, color = color.new(levelColor, 55), width = 1, style = line.style_dotted)
                    array.push(rsLines, leaderLine)
                if labelLayoutInput == "Rail"
                    railLabel = label.new(railXTime, labelY, labelText, xloc = xloc.bar_time, style = label.style_label_right, textcolor = color.white, color = color.rgb(15, 23, 42), size = labelSize())
                    array.push(rsLabels, railLabel)
                else
                    onLineLabel = label.new(onLineLabelTime(labelSlot), labelY, labelText, xloc = xloc.bar_time, style = label.style_none, textcolor = color.white, size = labelSize(), textalign = text.align_left)
                    array.push(rsLabels, onLineLabel)
                array.push(rsLabelKeys, labelKey)
        drawn := true
    drawn

drawZoneFill(topPrice, bottomPrice, kind) =>
    if showZoneFills and zoneKind(kind) and kindEnabled(kind) and not na(topPrice) and not na(bottomPrice) and array.size(rsBoxes) < 500
        zoneColor = kindColor(kind)
        zoneTop = math.max(topPrice, bottomPrice)
        zoneBottom = math.min(topPrice, bottomPrice)
        fillTransparency = 100 - zoneFillOpacityInput
        newBox = box.new(left = bar_index - 1, top = zoneTop, right = bar_index, bottom = zoneBottom, border_color = color.new(zoneColor, 100), border_width = 1, extend = extend.both, bgcolor = color.new(zoneColor, fillTransparency))
        array.push(rsBoxes, newBox)

drawZoneFills(levelText, maxCount) =>
    float bullTop = na
    float bullBottom = na
    float bearTop = na
    float bearBottom = na
    if levelText != "" and showZoneFills
        items = str.split(levelText, ";")
        count = math.min(array.size(items), maxCount)
        for i = 0 to count - 1
            fields = str.split(array.get(items, i), ",")
            if array.size(fields) >= 3
                name = array.get(fields, 0)
                price = str.tonumber(array.get(fields, 1))
                kind = levelKind(name, array.get(fields, 2))
                side = zoneBoundarySide(name)
                if not na(price) and zoneKind(kind) and kindEnabled(kind) and side != 0
                    if kind == "zone-bull"
                        if side == 1
                            bullTop := price
                        else
                            bullBottom := price
                        if not na(bullTop) and not na(bullBottom)
                            drawZoneFill(bullTop, bullBottom, kind)
                            bullTop := na
                            bullBottom := na
                    else if kind == "zone-bear"
                        if side == 1
                            bearTop := price
                        else
                            bearBottom := price
                        if not na(bearTop) and not na(bearBottom)
                            drawZoneFill(bearTop, bearBottom, kind)
                            bearTop := na
                            bearBottom := na
levelPriceRange(levelText, maxCount) =>
    float minPrice = na
    float maxPrice = na
    if levelText != ""
        items = str.split(levelText, ";")
        count = math.min(array.size(items), maxCount)
        for i = 0 to count - 1
            fields = str.split(array.get(items, i), ",")
            if array.size(fields) >= 3
                name = array.get(fields, 0)
                price = str.tonumber(array.get(fields, 1))
                kind = levelKind(name, array.get(fields, 2))
                if not na(price) and kindEnabled(kind)
                    minPrice := na(minPrice) ? price : math.min(minPrice, price)
                    maxPrice := na(maxPrice) ? price : math.max(maxPrice, price)
    not na(minPrice) and not na(maxPrice) ? math.max(maxPrice - minPrice, syminfo.mintick) : syminfo.mintick

drawLevelText(levelText, maxCount) =>
    drawnCount = 0
    totalCount = 0
    if levelText != ""
        items = str.split(levelText, ";")
        totalCount := array.size(items)
        count = math.min(totalCount, maxCount)
        priceRange = math.max(visibleBarRange, levelPriceRange(levelText, maxCount))
        drawZoneFills(levelText, maxCount)
        for i = 0 to count - 1
            fields = str.split(array.get(items, i), ",")
            if array.size(fields) >= 3
                name = array.get(fields, 0)
                kind = levelKind(name, array.get(fields, 2))
                price = str.tonumber(array.get(fields, 1))
                zoneSide = zoneBoundarySide(name)
                if drawLevel(name, array.get(fields, 1), array.get(fields, 2), priceRange, zoneSide)
                    drawnCount := drawnCount + 1
    [drawnCount, totalCount]

if barstate.islast
    clearDrawings()
    levelText = levelTextForChart(payload)
    drawStatsPanel(levelText)
    if levelText != ""
        [drawnCount, totalCount] = drawLevelText(levelText, maxLevelsInput)
