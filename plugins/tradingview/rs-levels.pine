//@version=6
indicator("RS Levels", overlay = true, max_lines_count = 500, max_labels_count = 500)

payload = input.string("", "RS Levels Payload")
showLabels = input.bool(true, "Labels")
showStatus = input.bool(true, "Status")
showDdBands = input.bool(true, "DD bands")
showHp = input.bool(true, "HP")
showMhp = input.bool(true, "MHP")
showOpenClose = input.bool(true, "Open/close")
showReference = input.bool(true, "References")
showZones = input.bool(true, "Zones")
showBullZones = input.bool(true, "Bull zones")
showBearZones = input.bool(true, "Bear zones")
showUnknown = input.bool(true, "Unknown")
lineWidth = input.int(1, "Line width", minval = 1, maxval = 4)
labelBarsOffset = input.int(1, "Label bar offset", minval = 0, maxval = 20)
labelVerticalOffset = input.int(6, "Label vertical offset (ticks)", minval = 1, maxval = 100)
maxLevelsInput = input.int(200, "Max levels", minval = 1, maxval = 500)
lineStyleInput = input.string("Solid", "Line style", options = ["Solid", "Dashed", "Dotted"])

var line[] rsLines = array.new_line()
var label[] rsLabels = array.new_label()

clearDrawings() =>
    while array.size(rsLines) > 0
        line.delete(array.pop(rsLines))
    while array.size(rsLabels) > 0
        label.delete(array.pop(rsLabels))

kindColor(kind) =>
    switch kind
        "dd-band" => color.rgb(41, 182, 246)
        "hp" => color.rgb(41, 98, 255)
        "mhp" => color.rgb(255, 152, 0)
        "open-close" => color.rgb(224, 224, 224)
        "reference" => color.rgb(255, 235, 59)
        "zone-bull" => color.rgb(76, 175, 80)
        "zone-bear" => color.rgb(240, 98, 146)
        "zone" => color.rgb(76, 175, 80)
        => color.rgb(158, 158, 158)

kindEnabled(kind) =>
    switch kind
        "dd-band" => showDdBands
        "hp" => showHp
        "mhp" => showMhp
        "open-close" => showOpenClose
        "reference" => showReference
        "zone-bull" => showZones and showBullZones
        "zone-bear" => showZones and showBearZones
        "zone" => showZones
        => showUnknown

lineStyle() =>
    switch lineStyleInput
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

chartPayloadSymbol() =>
    chartText = str.upper(syminfo.root + " " + syminfo.ticker)
    str.contains(chartText, "NQ") ? "MNQ" : str.contains(chartText, "ES") ? "MES" : ""

labelDirection(name, kind) =>
    upperName = str.upper(name)
    if str.contains(upperName, "LOWER") or str.contains(upperName, "BZB") or str.contains(upperName, "BRZB")
        -1
    else if str.contains(upperName, "UPPER") or str.contains(upperName, "BZT") or str.contains(upperName, "BRZT")
        1
    else
        switch kind
            "zone-bull" => -1
            "zone-bear" => 1
            "dd-band" => -1
            => 1

labelPrice(name, kind, price) =>
    tickOffset = math.max(labelVerticalOffset * syminfo.mintick, syminfo.mintick)
    price + tickOffset * labelDirection(name, kind)

drawLevel(name, priceText, kind) =>
    price = str.tonumber(priceText)
    drawn = false
    if not na(price) and kindEnabled(kind)
        levelColor = kindColor(kind)
        newLine = line.new(bar_index - 1, price, bar_index, price, extend = extend.both, color = levelColor, width = lineWidth, style = lineStyle())
        array.push(rsLines, newLine)
        if showLabels and array.size(rsLabels) < 499
            labelText = name + " " + str.tostring(price, format.mintick)
            labelY = labelPrice(name, kind, price)
            newLabel = label.new(bar_index + labelBarsOffset, labelY, labelText, style = label.style_label_left, textcolor = levelColor, color = color.new(color.black, 100), size = size.small)
            array.push(rsLabels, newLabel)
        drawn := true
    drawn

drawLevelText(levelText, maxCount) =>
    drawnCount = 0
    totalCount = 0
    if levelText != ""
        items = str.split(levelText, ";")
        totalCount := array.size(items)
        count = math.min(totalCount, maxCount)
        for i = 0 to count - 1
            fields = str.split(array.get(items, i), ",")
            if array.size(fields) >= 3
                if drawLevel(array.get(fields, 0), array.get(fields, 1), array.get(fields, 2))
                    drawnCount := drawnCount + 1
    [drawnCount, totalCount]

drawStatus(validPayload, symbolText, capturedText, drawnCount, totalCount) =>
    if showStatus and array.size(rsLabels) < 500
        statusText = validPayload ? "RS Levels " + symbolText + " " + str.tostring(drawnCount) + "/" + str.tostring(totalCount) + " " + capturedText : "RS Levels: paste RSLEVELS payload"
        statusColor = validPayload ? color.new(color.rgb(18, 54, 93), 0) : color.new(color.rgb(80, 39, 39), 0)
        statusTextColor = validPayload ? color.rgb(234, 245, 255) : color.rgb(255, 190, 190)
        newStatus = label.new(bar_index, high, statusText, style = label.style_label_down, textcolor = statusTextColor, color = statusColor, size = size.small)
        array.push(rsLabels, newStatus)

if barstate.islast
    clearDrawings()
    parts = str.split(payload, "|")
    validPayload = array.size(parts) >= 5 and array.get(parts, 0) == "RSLEVELS" and (array.get(parts, 1) == "1" or array.get(parts, 1) == "2")
    payloadVersion = validPayload ? array.get(parts, 1) : ""
    symbolText = ""
    capturedText = ""
    levelText = ""
    drawnCount = 0
    totalCount = 0
    if validPayload and payloadVersion == "1"
        symbolText := array.get(parts, 2)
        capturedText := array.get(parts, 3)
        levelText := array.get(parts, 4)
    if validPayload and payloadVersion == "2"
        chartSymbol = chartPayloadSymbol()
        sectionCount = int(math.floor((array.size(parts) - 3) / 3))
        fallbackSymbol = sectionCount == 1 ? array.get(parts, 3) : ""
        sectionIndex = 3
        while sectionIndex + 2 < array.size(parts)
            candidateSymbol = array.get(parts, sectionIndex)
            if symbolText == "" and (candidateSymbol == chartSymbol or (chartSymbol == "" and fallbackSymbol != "" and candidateSymbol == fallbackSymbol))
                symbolText := candidateSymbol
                capturedText := array.get(parts, sectionIndex + 1)
                levelText := array.get(parts, sectionIndex + 2)
            sectionIndex += 3
    if validPayload
        [nextDrawnCount, nextTotalCount] = drawLevelText(levelText, maxLevelsInput)
        drawnCount := nextDrawnCount
        totalCount := nextTotalCount
    drawStatus(validPayload, symbolText, capturedText, drawnCount, totalCount)
