{
  "manifest_version": 3,
  "name": "RS Levels Capture",
  "description": "Capture RocketScooter display levels into the local RS Levels API.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://rocket.place/*",
    "https://*.rocket.place/*",
    "https://rocketscooter.com/*",
    "https://*.rocketscooter.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "RS Levels",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://rocket.place/*",
        "https://*.rocket.place/*",
        "https://rocketscooter.com/*",
        "https://*.rocketscooter.com/*"
      ],
      "js": [
        "src/shared.js",
        "src/content-script.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://rocket.place/*",
        "https://*.rocket.place/*",
        "https://rocketscooter.com/*",
        "https://*.rocketscooter.com/*"
      ],
      "js": [
        "src/capture-rules.js",
        "src/page-hook.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/capture-rules.js",
        "src/page-hook.js"
      ],
      "matches": [
        "https://rocket.place/*",
        "https://*.rocket.place/*",
        "https://rocketscooter.com/*",
        "https://*.rocketscooter.com/*"
      ]
    }
  ]
}
